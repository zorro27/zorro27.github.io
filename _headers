# Рекомендуемые security-заголовки для боевого хостинга (формат Netlify _headers).
# Если хостинг другой (Nginx/Apache/облако) — перенесите те же директивы
# в конфиг сервера или в мета-теги. Сам файл не активируется на статическом
# файловом хостинге без соответствующей платформы (Netlify/Cloudflare Pages и т.п.).

/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
